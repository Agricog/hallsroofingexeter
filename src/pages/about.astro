---
import { Icon } from 'astro-icon/components'
import { CLIENT } from '../data/clientConfig'
import { buildStructuredData, getBreadcrumbSchema } from '../utils/seo'
import type { SeoPageData } from '../types'
import BaseLayout from '../layouts/BaseLayout.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import CtaSection from '../components/CtaSection.astro'
import AiChatIntake from '../components/react/AiChatIntake'

const BASE_URL = `https://${CLIENT.domain}`

const page: SeoPageData = {
  title: `About ${CLIENT.businessName} | Roofing Quotes in ${CLIENT.area}`,
  description: `${CLIENT.businessName} helps homeowners across ${CLIENT.area} and ${CLIENT.region} get a roofing quote fast. Describe your job to our AI assistant and get a same-day callback. Free, no obligation.`,
  canonical: `${BASE_URL}/about`,
  ogImage: `${BASE_URL}/og-image.jpg`,
  type: 'website',
  keywords: [`roofer ${CLIENT.area.toLowerCase()}`, `roofing quotes ${CLIENT.area.toLowerCase()}`],
}

const structuredData = buildStructuredData(page, [
  getBreadcrumbSchema([
    { name: 'Home', url: BASE_URL },
    { name: 'About', url: page.canonical },
  ]),
])

const highlights = [
  { icon: 'lucide:clock', value: '30 Seconds', label: 'To scope your job' },
  { icon: 'lucide:check-circle', value: 'Free', label: 'No-obligation quotes' },
  { icon: 'lucide:map-pin', value: 'Local', label: `${CLIENT.area} & ${CLIENT.region}` },
  { icon: 'lucide:phone', value: 'Same Day', label: 'Callback' },
]
---

<BaseLayout page={page} structuredData={structuredData}>
  <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'About' }]} />

  <!-- Hero -->
  <section class="py-12 md:py-20 px-4">
    <div class="mx-auto max-w-4xl text-center">
      <h1 class="font-heading text-[clamp(28px,5vw,44px)] leading-[1.1] text-slate-800 mb-5">
        About <span style="color: var(--color-brand);">{CLIENT.businessName}</span>
      </h1>
      <p class="text-lg text-slate-500 leading-relaxed max-w-2xl mx-auto">
        {CLIENT.businessName} is a roofing quote service for {CLIENT.area} and {CLIENT.region}. Describe your job to our AI assistant and you'll get a same-day callback with a quote from a local roofer — no forms, no waiting, no call-out fee.
      </p>
    </div>
  </section>

  <!-- Highlights -->
  <section class="px-4 pb-16">
    <div class="mx-auto max-w-4xl">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {highlights.map((h) => (
          <div class="card p-5 text-center">
            <Icon name={h.icon} size={24} class="mx-auto mb-2" style="color: var(--color-brand);" />
            <div class="font-heading text-xl text-slate-800">{h.value}</div>
            <div class="text-xs text-slate-500 mt-0.5">{h.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Story -->
  <section class="py-16 px-4 section-warm">
    <div class="mx-auto max-w-3xl">
      <div class="text-[15px] text-slate-600 leading-[1.85] space-y-5">
        <h2 class="font-heading text-2xl text-slate-800 mb-4">How {CLIENT.businessName} Works</h2>
        <p>
          Getting a roofing quote in {CLIENT.area} usually means chasing tradespeople, leaving voicemails, and waiting days for a callback that often never comes. We built {CLIENT.businessName} to fix that.
        </p>
        <p>
          Tell our AI assistant about your roof — it asks a few simple questions, scopes the job in about 30 seconds, and gives you an instant indicative price. A clear summary of the job then goes to a local roofer, who calls you back the same day with a proper quote. You get the speed of an instant estimate and the certainty of a real human quote, and the roofer arrives already knowing what the job involves.
        </p>

        <h2 class="font-heading text-2xl text-slate-800 !mt-10 mb-4">Why Use {CLIENT.businessName}</h2>
        <p>
          No forms and no photo uploads — just a 30-second chat. No call-out fee and no obligation: you get an indicative price and a callback, and you decide whether to go ahead. No high-pressure sales — the quote is yours to consider in your own time.
        </p>
        <p>
          Because the assistant scopes your job before any roofer calls, you skip the vague back-and-forth that wastes everyone's time. The roofer who calls you knows the property type, the likely materials, and the scope of the work before they pick up the phone — which means a faster, more accurate quote for you.
        </p>

        <h2 class="font-heading text-2xl text-slate-800 !mt-10 mb-4">Roofing Jobs We Cover</h2>
        <p>We can get you a quote for the full range of domestic and commercial roofing work across {CLIENT.area} and {CLIENT.region}:</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 my-4">
          {CLIENT.services.map((s) => (
            <a
              href={`/services/${s.slug}`}
              class="flex items-center gap-2 text-sm no-underline text-slate-600 hover:text-amber-700 transition-colors"
            >
              <Icon name="lucide:check-circle" size={15} style="color: var(--color-success);" />
              {s.name} — from £{s.priceFrom}
            </a>
          ))}
        </div>

        <h2 class="font-heading text-2xl text-slate-800 !mt-10 mb-4">Get in Touch</h2>
        <p>
          Whether you have an emergency leak, want a quote for a full reroof, or just need advice on the best option for your roof, start with the chat below — it takes under a minute. Or call us directly on {CLIENT.phone}. Either way, you'll get a quick, no-obligation response.
        </p>
      </div>
    </div>
  </section>

  <!-- Chat section -->
  <section id="quote" class="py-12 px-4">
    <div class="mx-auto max-w-6xl">
      <div class="flex flex-col lg:flex-row items-center gap-8 lg:gap-12">
        <div class="flex-1 text-center lg:text-left">
          <h2 class="font-heading text-2xl md:text-[32px] text-slate-800 mb-3">
            Get your free quote
          </h2>
          <p class="text-slate-500">
            Tell our AI assistant about your roof and we'll call you back the same day.
          </p>
        </div>
        <div class="flex-1 flex justify-center w-full max-w-[440px]">
          <AiChatIntake client:visible />
        </div>
      </div>
    </div>
  </section>

  <CtaSection />
</BaseLayout>
