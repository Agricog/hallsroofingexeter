---
// ============================================================
// Homepage — Hero+Chat > Trust > Services > How > Pricing >
// Why > Areas > FAQ > CTA > SEO Content
// ============================================================
import { Icon } from 'astro-icon/components'
import { CLIENT } from '../data/clientConfig'
import { getHomepageStructuredData } from '../utils/seo'
import BaseLayout from '../layouts/BaseLayout.astro'
import TrustStrip from '../components/TrustStrip.astro'
import ServiceCard from '../components/ServiceCard.astro'
import FaqSection from '../components/FaqSection.astro'
import CtaSection from '../components/CtaSection.astro'
import AiChatIntake from '../components/react/AiChatIntake'

const { page, data } = getHomepageStructuredData()
const phoneClean = CLIENT.phone.replace(/\s/g, '')
const yearsInBusiness = new Date().getFullYear() - CLIENT.yearEstablished

const TRUST_ITEMS = [
  { icon: 'lucide:star', text: `${CLIENT.googleReviewRating}/5 (${CLIENT.googleReviewCount} reviews)` },
  { icon: 'lucide:shield-check', text: `£${CLIENT.insuranceAmount} insured` },
  { icon: 'lucide:check-circle', text: 'All work guaranteed' },
]

const HOW_IT_WORKS = [
  {
    step: '1',
    title: 'Tell us about your roof',
    description:
      'Chat with our AI assistant for 30 seconds. It asks three simple questions about your job — no forms, no photo uploads.',
  },
  {
    step: '2',
    title: 'Get an instant estimate',
    description: `See a price range for your job straight away based on current ${CLIENT.area} pricing, so you know what to expect.`,
  },
  {
    step: '3',
    title: `${CLIENT.ownerName} calls you back`,
    description: `Pick a time that suits you. ${CLIENT.ownerName} calls with a detailed quote. No chasing, no missed calls — just a confirmed callback.`,
  },
]

const TRUST_ICON_MAP: Record<string, string> = {
  'shield-check': 'lucide:shield-check',
  clock: 'lucide:clock',
  'map-pin': 'lucide:map-pin',
  'badge-check': 'lucide:check-circle',
}
---

<BaseLayout page={page} structuredData={data}>
  <!-- ── HERO + AI CHAT ─────────────────────── -->
  <section
    id="quote"
    class="relative overflow-hidden"
    style="background: linear-gradient(180deg, var(--color-slate-50) 0%, white 100%);"
  >
    <div
      class="absolute inset-0 opacity-[0.03] pointer-events-none"
      style="background-image: radial-gradient(circle at 1px 1px, var(--color-slate-600) 1px, transparent 0); background-size: 32px 32px;"
      aria-hidden="true"
    />

    <div class="mx-auto max-w-6xl px-4 py-12 md:py-20 relative">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
        <!-- Left: Copy -->
        <div class="flex-1 text-center lg:text-left">
          <div
            class="inline-flex items-center gap-2 text-xs font-semibold px-3.5 py-1.5 rounded-full mb-5"
            style="background: var(--color-brand-50); color: var(--color-brand-dark);"
          >
            <Icon name="lucide:map-pin" size={14} />
            Serving {CLIENT.area} & {CLIENT.region}
          </div>

          <h1 class="font-heading text-[clamp(32px,5.5vw,52px)] leading-[1.08] text-slate-800 mb-5">
            Trusted roofers in <span style="color: var(--color-brand);">{CLIENT.area}</span> for over {yearsInBusiness} years
          </h1>

          <p class="text-lg text-slate-500 leading-relaxed mb-8 max-w-xl mx-auto lg:mx-0">
            Tell us what you need — our AI assistant will scope your job in 30 seconds. {CLIENT.ownerName} calls you back with a quote at a time that suits you. No obligation, no call-out fee.
          </p>

          <!-- CTA Buttons -->
          <div class="flex flex-wrap gap-3 justify-center lg:justify-start mb-8">
            <a
              href="#quote"
              class="btn-primary !py-3.5 !px-7 no-underline"
              data-scroll-to-chat
              data-track="cta:hero"
            >
              Get a Free Quote
              <Icon name="lucide:chevron-right" size={18} />
            </a>
            <a
              href={`tel:${phoneClean}`}
              class="btn-secondary !py-3.5 !px-7"
              data-track="phone_call:hero"
            >
              <Icon name="lucide:phone" size={17} />
              {CLIENT.phone}
            </a>
          </div>

          <!-- Mini trust signals -->
          <div class="flex flex-wrap gap-5 justify-center lg:justify-start">
            {TRUST_ITEMS.map((item) => (
              <div class="flex items-center gap-1.5 text-sm text-slate-500">
                <Icon name={item.icon} size={15} style="color: var(--color-success);" />
                {item.text}
              </div>
            ))}
          </div>
        </div>

        <!-- Right: AI Chat (React Island) -->
        <div class="flex-1 flex justify-center w-full max-w-[440px]">
          <AiChatIntake client:visible />
        </div>
      </div>
    </div>
  </section>

  <!-- ── TRUST STRIP ────────────────────────── -->
  <TrustStrip />

  <!-- ── SERVICES ───────────────────────────── -->
  <section class="py-16 md:py-20 px-4" id="services">
    <div class="mx-auto max-w-6xl">
      <div class="text-center mb-12">
        <p
          class="text-xs font-semibold uppercase tracking-[2px] mb-2"
          style="color: var(--color-brand);"
        >
          Our Services
        </p>
        <h2 class="font-heading text-2xl md:text-[32px] text-slate-800 mb-3">
          Roofing services across {CLIENT.area}
        </h2>
        <p class="text-slate-500 max-w-lg mx-auto">
          From emergency leak repairs to full reroofs, we handle every aspect of domestic and commercial roofing in {CLIENT.region}.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {CLIENT.services.map((service) => (
          <ServiceCard service={service} />
        ))}
      </div>
    </div>
  </section>

  <!-- ── HOW IT WORKS ───────────────────────── -->
  <section class="py-16 md:py-20 px-4 section-warm">
    <div class="mx-auto max-w-4xl">
      <div class="text-center mb-12">
        <p
          class="text-xs font-semibold uppercase tracking-[2px] mb-2"
          style="color: var(--color-brand);"
        >
          How It Works
        </p>
        <h2 class="font-heading text-2xl md:text-[32px] text-slate-800">
          Three steps to your quote
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {HOW_IT_WORKS.map((item) => (
          <div class="text-center">
            <div
              class="w-14 h-14 rounded-2xl flex items-center justify-center font-heading text-xl mx-auto mb-4"
              style="background: var(--color-brand); color: white;"
            >
              {item.step}
            </div>
            <h3 class="font-heading text-lg text-slate-800 mb-2">
              {item.title}
            </h3>
            <p class="text-sm text-slate-500 leading-relaxed">
              {item.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── PRICING GUIDE ──────────────────────── -->
  <section class="py-16 md:py-20 px-4" id="pricing">
    <div class="mx-auto max-w-4xl">
      <div class="text-center mb-12">
        <p
          class="text-xs font-semibold uppercase tracking-[2px] mb-2"
          style="color: var(--color-brand);"
        >
          Pricing Guide
        </p>
        <h2 class="font-heading text-2xl md:text-[32px] text-slate-800 mb-3">
          Roofing costs in {CLIENT.area}
        </h2>
        <p class="text-slate-500 max-w-lg mx-auto">
          Indicative pricing based on typical jobs. Your quote depends on job scope, materials, and access. All quotes are free and include a full inspection.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {CLIENT.estimateRange.map((range) => (
          <div class="card p-5 text-center">
            <div class="text-xs text-slate-400 font-medium uppercase tracking-wider mb-2">
              {range.size}
            </div>
            <div class="font-heading text-xl text-slate-800">
              £{range.low.toLocaleString()}–£{range.high.toLocaleString()}
            </div>
            <div class="text-xs text-slate-400 mt-1">typical range</div>
          </div>
        ))}
      </div>

      {CLIENT.discountActive && (
        <div
          class="mt-6 p-4 rounded-xl text-center text-sm"
          style="background: var(--color-brand-50); border: 1px solid rgba(217, 119, 6, 0.15); color: var(--color-brand-dark);"
        >
          ⚡ {CLIENT.discountPercent}% off all quotes this week —{' '}
          <a
            href="#quote"
            class="font-semibold underline"
            style="color: var(--color-brand-dark);"
            data-scroll-to-chat
            data-track="cta:discount_pricing"
          >
            get your free quote now
          </a>
        </div>
      )}
    </div>
  </section>

  <!-- ── WHY CHOOSE US ──────────────────────── -->
  <section class="py-16 md:py-20 px-4 section-warm">
    <div class="mx-auto max-w-4xl">
      <div class="text-center mb-12">
        <p
          class="text-xs font-semibold uppercase tracking-[2px] mb-2"
          style="color: var(--color-brand);"
        >
          Why Choose Us
        </p>
        <h2 class="font-heading text-2xl md:text-[32px] text-slate-800">
          Why {CLIENT.area} trusts {CLIENT.businessName}
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {CLIENT.trustSignals.map((signal) => {
          const iconName = TRUST_ICON_MAP[signal.icon] || 'lucide:check-circle'
          return (
            <div class="card p-6 flex gap-4 items-start">
              <div
                class="w-11 h-11 rounded-xl flex items-center justify-center shrink-0"
                style="background: var(--color-brand-50);"
              >
                <Icon name={iconName} size={20} style="color: var(--color-brand);" />
              </div>
              <div>
                <h3 class="font-semibold text-slate-800 mb-1">{signal.title}</h3>
                <p class="text-sm text-slate-500 leading-relaxed">{signal.description}</p>
              </div>
            </div>
          )
        })}
      </div>
    </div>
  </section>

  <!-- ── AREAS SERVED ───────────────────────── -->
  <section class="py-16 md:py-20 px-4" id="areas">
    <div class="mx-auto max-w-4xl">
      <div class="text-center mb-10">
        <p
          class="text-xs font-semibold uppercase tracking-[2px] mb-2"
          style="color: var(--color-brand);"
        >
          Areas We Cover
        </p>
        <h2 class="font-heading text-2xl md:text-[32px] text-slate-800 mb-3">
          Roofers across {CLIENT.area} and {CLIENT.region}
        </h2>
        <p class="text-slate-500 max-w-lg mx-auto">
          We provide roofing services across {CLIENT.area} and the surrounding {CLIENT.region} area. Click an area to see local pricing and availability.
        </p>
      </div>

      <div class="flex flex-wrap gap-2.5 justify-center">
        {CLIENT.areasServed.map((area) => (
          <a
            href={`/areas/${area.slug}`}
            class="inline-flex items-center gap-1.5 px-4 py-2.5 rounded-full bg-white border border-slate-200 text-sm text-slate-600 font-medium no-underline hover:border-amber-300 hover:text-amber-700 transition-colors"
          >
            <Icon name="lucide:map-pin" size={13} />
            {area.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── FAQ ─────────────────────────────────── -->
  <section class="py-16 md:py-20 px-4 section-warm" id="faq">
    <FaqSection />
  </section>

  <!-- ── BOTTOM CTA ─────────────────────────── -->
  <CtaSection />

  <!-- ── SEO CONTENT ────────────────────────── -->
  <section class="py-16 px-4 bg-white border-t border-slate-100">
    <article class="mx-auto max-w-3xl">
      <h2 class="font-heading text-2xl text-slate-800 mb-6">
        Roofing Services in {CLIENT.area} — {CLIENT.businessName}
      </h2>

      <div class="text-[15px] text-slate-500 leading-[1.85] space-y-5">
        <p>
          {CLIENT.businessName} is an established roofing company serving {CLIENT.area} and the wider {CLIENT.region} area. With over {yearsInBusiness} years of experience, we provide a full range of domestic and commercial roofing services including roof repairs, complete reroofs, flat roofing, chimney work, and guttering. Every job comes with a written guarantee and is covered by our £{CLIENT.insuranceAmount} public liability insurance.
        </p>

        <h3 class="font-heading text-lg text-slate-700 !mt-8 !mb-3">
          Why Choose a Local Roofer in {CLIENT.area}?
        </h3>
        <p>
          Choosing a local roofer matters. A roofer based in {CLIENT.area} can respond faster to emergencies, has experience with the specific property types and weather conditions in {CLIENT.region}, and is invested in their local reputation. We have worked on properties across every part of {CLIENT.area} — from period homes in the city centre to modern estates on the outskirts — and we understand the unique challenges each property type presents.
        </p>

        <h3 class="font-heading text-lg text-slate-700 !mt-8 !mb-3">
          How Much Does Roofing Cost in {CLIENT.area}?
        </h3>
        <p>
          Roofing costs in {CLIENT.area} depend on the type of work required. A straightforward repair for a leak or a few slipped tiles typically costs between £{CLIENT.estimateRange[0].low} and £{CLIENT.estimateRange[0].high}. Chimney repointing and reflashing ranges from £{CLIENT.estimateRange[1].low} to £{CLIENT.estimateRange[1].high}. A full reroof on a standard semi-detached home is typically £{CLIENT.estimateRange[3].low.toLocaleString()} to £{CLIENT.estimateRange[3].high.toLocaleString()}, depending on the size of the roof, the pitch, and the materials chosen. We provide free, no-obligation quotes on every job so you know the exact cost before any work starts.
        </p>

        <h3 class="font-heading text-lg text-slate-700 !mt-8 !mb-3">
          Emergency Roof Repairs
        </h3>
        <p>
          When you have an active leak or storm damage, you need a roofer who can attend quickly. We offer same-day emergency attendance across {CLIENT.area} and {CLIENT.region}. Our vans carry emergency tarpaulins and common repair materials so we can make your property watertight on the first visit. Emergency repairs are charged at our standard rates — no inflated call-out fees.
        </p>

        <h3 class="font-heading text-lg text-slate-700 !mt-8 !mb-3">
          Our Roofing Process
        </h3>
        <p>
          Every job follows the same clear process. First, you tell us what you need — either through our online quote tool or by phone. We then arrange a convenient time to visit your property and carry out a full roof inspection. We provide a detailed written quote with no hidden costs. Once approved, we schedule the work at a time that suits you, complete it to the highest standard, and issue your guarantee certificate. We leave the site clean and tidy and follow up to make sure you are completely satisfied.
        </p>

        <h3 class="font-heading text-lg text-slate-700 !mt-8 !mb-3">
          Types of Roofing We Work With
        </h3>
        <p>
          We work with all common roofing types found in {CLIENT.region} including pitched roofs with concrete or clay tiles, natural slate roofs, flat roofs with felt, GRP fibreglass, or EPDM rubber, and lead work around chimneys, valleys, and dormers. Whether your property is a Victorian terrace, a 1930s semi, a modern new build, or a commercial unit, we have the experience and materials to handle the job.
        </p>

        <h3 class="font-heading text-lg text-slate-700 !mt-8 !mb-3">
          Areas We Cover Near {CLIENT.area}
        </h3>
        <p>
          We provide roofing services across {CLIENT.area} and the surrounding areas of {CLIENT.region}, including {CLIENT.areasServed.map((a) => a.name).join(', ')}. If you are unsure whether we cover your location, contact us — we probably do.
        </p>

        <h3 class="font-heading text-lg text-slate-700 !mt-8 !mb-3">
          Our Guarantee
        </h3>
        <p>
          We stand behind every job we do. Repairs come with a 12-month written guarantee. Full reroofs are guaranteed for 20 years on materials and workmanship. Flat roofs are guaranteed for the lifetime of the membrane system — typically 25 years or more. We also carry £{CLIENT.insuranceAmount} public liability insurance on every job, so you are fully protected from day one.
        </p>

        <h3 class="font-heading text-lg text-slate-700 !mt-8 !mb-3">
          Get Your Free Quote Today
        </h3>
        <p>
          Use our quick quote tool at the top of this page to tell us about your roofing job. It takes less than 30 seconds and {CLIENT.ownerName} will call you back at a time that suits you with a detailed quote. Alternatively, call us directly on {CLIENT.phone}. No obligation, no pressure — just a straightforward quote from a local roofer who knows {CLIENT.area}.
        </p>
      </div>
    </article>
  </section>
</BaseLayout>
