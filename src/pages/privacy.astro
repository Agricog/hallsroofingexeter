---
import { CLIENT } from '../data/clientConfig'
import { buildStructuredData, getBreadcrumbSchema } from '../utils/seo'
import type { SeoPageData } from '../types'
import BaseLayout from '../layouts/BaseLayout.astro'
import Breadcrumb from '../components/Breadcrumb.astro'

const BASE_URL = `https://${CLIENT.domain}`

const page: SeoPageData = {
  title: `Privacy Policy | ${CLIENT.businessName}`,
  description: `Privacy policy for ${CLIENT.businessName}. How we collect, use, and share your personal information.`,
  canonical: `${BASE_URL}/privacy`,
  ogImage: `${BASE_URL}/og-image.jpg`,
  type: 'website',
  keywords: [],
}

const structuredData = buildStructuredData(page, [
  getBreadcrumbSchema([
    { name: 'Home', url: BASE_URL },
    { name: 'Privacy Policy', url: page.canonical },
  ]),
])

const lastUpdated = new Date().toLocaleDateString('en-GB', { month: 'long', year: 'numeric' })
---

<BaseLayout page={page} structuredData={structuredData}>
  <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Privacy Policy' }]} />

  <section class="py-12 md:py-20 px-4">
    <div class="mx-auto max-w-3xl">
      <h1 class="font-heading text-[clamp(28px,5vw,44px)] leading-[1.1] text-slate-800 mb-8">
        Privacy Policy
      </h1>

      <div class="text-[15px] text-slate-600 leading-[1.85] space-y-5">
        <p class="text-sm text-slate-400">Last updated: {lastUpdated}</p>

        <h2 class="font-heading text-2xl text-slate-800 !mt-10 mb-4">Who We Are</h2>
        <p>
          {CLIENT.businessName} provides a roofing quote service for {CLIENT.area} and {CLIENT.region}: we help you get a roofing quote from a local roofer. This privacy policy explains how we collect, use, and share your personal information when you use our website ({CLIENT.domain}) or contact us for a quote. We do not carry out roofing work ourselves.
        </p>

        <h2 class="font-heading text-2xl text-slate-800 !mt-10 mb-4">What We Collect</h2>
        <p>
          When you use our website chat or contact us, we may collect your name, telephone number, email address, property address, and details about the roofing work you need. We collect this so we can give you an estimate and connect you with a local roofer who can provide a quote.
        </p>

        <h2 class="font-heading text-2xl text-slate-800 !mt-10 mb-4">How We Use Your Information</h2>
        <p>We use your personal information to:</p>
        <ul class="list-disc pl-6 space-y-1">
          <li>Respond to your enquiry and give you an indicative estimate</li>
          <li>Share your details with a local roofer so they can contact you with a quote</li>
          <li>Send you a follow-up message about your enquiry</li>
          <li>Comply with our legal obligations</li>
        </ul>

        <h2 class="font-heading text-2xl text-slate-800 !mt-10 mb-4">Sharing Your Information</h2>
        <p>
          To provide our service, we share the details you give us with a local roofer in your area so they can contact you with a quote. This sharing is necessary to provide the quote you have asked for. The roofer is a separate business and will handle your information under their own privacy policy once it has been shared with them.
        </p>
        <p>
          We do not sell your information for unrelated marketing. Other than the roofer providing your quote, we only share your information with the service providers we use to operate this website and contact you — for example, our hosting and messaging providers — who act on our instructions.
        </p>

        <h2 class="font-heading text-2xl text-slate-800 !mt-10 mb-4">AI Chat</h2>
        <p>
          Our website uses an AI-powered chat assistant to help you get a quick estimate. The conversation is processed to understand your roofing needs and produce an estimate, and may be handled by third-party AI service providers acting on our behalf. Your conversation and contact details are stored securely so we can follow up with you and pass your quote request to a roofer. The chat is not monitored in real time by a person.
        </p>

        <h2 class="font-heading text-2xl text-slate-800 !mt-10 mb-4">SMS and WhatsApp Messages</h2>
        <p>
          When you provide your phone number, we may send you a confirmation message to let you know we have received your enquiry. We may also send a follow-up message if we have not been able to reach you. You can opt out of messages at any time by replying STOP.
        </p>

        <h2 class="font-heading text-2xl text-slate-800 !mt-10 mb-4">How We Store Your Data</h2>
        <p>
          Your data is stored securely on encrypted servers. We keep your contact details and enquiry information only for as long as needed to provide the service and to meet our legal obligations, after which it is deleted. You can request deletion of your data at any time by contacting us.
        </p>

        <h2 class="font-heading text-2xl text-slate-800 !mt-10 mb-4">Your Rights</h2>
        <p>
          Under UK GDPR, you have the right to access, correct, or delete your personal data. You also have the right to object to processing and to data portability. To exercise any of these rights, contact us using the details below.
        </p>

        <h2 class="font-heading text-2xl text-slate-800 !mt-10 mb-4">Cookies</h2>
        <p>
          This website uses cookies that are necessary for it to function. We also record basic information about how visitors use the site, such as which links and buttons are clicked, to help us improve it.
        </p>

        <h2 class="font-heading text-2xl text-slate-800 !mt-10 mb-4">Contact</h2>
        <p>If you have any questions about this privacy policy or want to exercise your data rights, contact us at:</p>
        <p>
          {CLIENT.businessName}<br />
          Phone: {CLIENT.phone}<br />
          Email: info@{CLIENT.domain}
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
