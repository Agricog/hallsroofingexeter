---
import { CLIENT } from '../data/clientConfig'
import { buildStructuredData, getBreadcrumbSchema } from '../utils/seo'
import type { SeoPageData } from '../types'
import BaseLayout from '../layouts/BaseLayout.astro'
import Breadcrumb from '../components/Breadcrumb.astro'

const BASE_URL = `https://${CLIENT.domain}`

const page: SeoPageData = {
  title: `Terms of Service | ${CLIENT.businessName}`,
  description: `Terms of service for ${CLIENT.businessName}. Our terms and conditions for the roofing quote service and use of this website.`,
  canonical: `${BASE_URL}/terms`,
  ogImage: `${BASE_URL}/og-image.jpg`,
  type: 'website',
  keywords: [],
}

const structuredData = buildStructuredData(page, [
  getBreadcrumbSchema([
    { name: 'Home', url: BASE_URL },
    { name: 'Terms of Service', url: page.canonical },
  ]),
])

const lastUpdated = new Date().toLocaleDateString('en-GB', { month: 'long', year: 'numeric' })
---

<BaseLayout page={page} structuredData={structuredData}>
  <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Terms of Service' }]} />

  <section class="py-12 md:py-20 px-4">
    <div class="mx-auto max-w-3xl">
      <h1 class="font-heading text-[clamp(28px,5vw,44px)] leading-[1.1] text-slate-800 mb-8">
        Terms of Service
      </h1>

      <div class="text-[15px] text-slate-600 leading-[1.85] space-y-5">
        <p class="text-sm text-slate-400">Last updated: {lastUpdated}</p>

        <h2 class="font-heading text-2xl text-slate-800 !mt-10 mb-4">Overview</h2>
        <p>
          These terms govern your use of the {CLIENT.businessName} website ({CLIENT.domain}) and the roofing quote service we provide through it. By using this website or our quote service, you agree to these terms.
        </p>
        <p>
          {CLIENT.businessName} provides a quote and callback service: we help you get a roofing quote from a local roofer. We do not carry out roofing work ourselves.
        </p>

        <h2 class="font-heading text-2xl text-slate-800 !mt-10 mb-4">How Our Quotes Work</h2>
        <p>
          The price ranges shown on this website and given by our AI assistant are indicative estimates only, based on typical job costs. They are not firm quotes and are not binding. A firm quote is provided by the local roofer after they have assessed your job, usually following a phone call and, where needed, a site visit.
        </p>
        <p>
          Estimates may vary from the final quote depending on access, materials, and the condition of your roof. Written quotes provided by a roofer are valid for the period stated by that roofer.
        </p>

        <h2 class="font-heading text-2xl text-slate-800 !mt-10 mb-4">The Roofing Work</h2>
        <p>
          Any roofing work is contracted directly between you and the roofer who provides your quote. That roofer is responsible for the work, including their own pricing, guarantees, insurance, and compliance with building regulations. {CLIENT.businessName} is not a party to that contract and is not responsible for the work carried out, its quality, or any guarantee given.
        </p>
        <p>
          We recommend you confirm the roofer's public liability insurance and the terms of any guarantee in writing before agreeing to any work.
        </p>

        <h2 class="font-heading text-2xl text-slate-800 !mt-10 mb-4">Sharing Your Details</h2>
        <p>
          To get you a quote, we share the details you provide through the chat or by phone with a local roofer so they can contact you. We only share what is needed to provide your quote. For full details of how we handle your information, see our <a href="/privacy" class="underline" style="color: var(--color-brand-dark);">Privacy Policy</a>.
        </p>

        <h2 class="font-heading text-2xl text-slate-800 !mt-10 mb-4">Website Use</h2>
        <p>
          This website is provided for information and to help you get a roofing quote. The AI assistant provides estimated prices based on typical costs; these are not binding quotes. All content on this website is owned by {CLIENT.businessName} and may not be reproduced without permission.
        </p>

        <h2 class="font-heading text-2xl text-slate-800 !mt-10 mb-4">Limitation of Liability</h2>
        <p>
          While we take care to keep the information on this website accurate, we do not guarantee that it is error-free. {CLIENT.businessName} is not liable for any loss arising from your use of this website, from reliance on estimates provided by the AI assistant, or from any roofing work carried out by a roofer introduced through this service.
        </p>

        <h2 class="font-heading text-2xl text-slate-800 !mt-10 mb-4">Governing Law</h2>
        <p>
          These terms are governed by the laws of England and Wales. Any disputes will be subject to the exclusive jurisdiction of the courts of England and Wales.
        </p>

        <h2 class="font-heading text-2xl text-slate-800 !mt-10 mb-4">Contact</h2>
        <p>If you have any questions about these terms, contact us at:</p>
        <p>
          {CLIENT.businessName}<br />
          Phone: {CLIENT.phone}<br />
          Email: info@{CLIENT.domain}
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
