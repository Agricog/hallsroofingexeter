---
// ============================================================
// Emergency Page
// ============================================================
import { Icon } from 'astro-icon/components'
import { CLIENT } from '../data/clientConfig'
import {
  getLocalBusinessSchema,
  getWebSiteSchema,
  getBreadcrumbSchema,
} from '../utils/seo'
import type { SeoPageData } from '../types'
import BaseLayout from '../layouts/BaseLayout.astro'
import CtaSection from '../components/CtaSection.astro'
import FaqSection from '../components/FaqSection.astro'
import AiChatIntake from '../components/react/AiChatIntake'

const BASE_URL = `https://${CLIENT.domain}`
const phoneClean = CLIENT.phone.replace(/\s/g, '')

const page: SeoPageData = {
  title: `Emergency Roofer ${CLIENT.area} | Same-Day Callback | ${CLIENT.businessName}`,
  description: `Emergency roof repair in ${CLIENT.area}? Get a same-day callback from a local roofer for leaks and storm damage. Free quote, no call-out fee. Call ${CLIENT.phone} or use the chat. ${CLIENT.businessName}.`,
  canonical: `${BASE_URL}/emergency`,
  ogImage: `${BASE_URL}/og-image.jpg`,
  type: 'website',
  keywords: [
    `emergency roofer ${CLIENT.area.toLowerCase()}`,
    `emergency roof repair ${CLIENT.area.toLowerCase()}`,
    `leaking roof ${CLIENT.area.toLowerCase()}`,
    `storm damage roof ${CLIENT.area.toLowerCase()}`,
    `same day roofer ${CLIENT.area.toLowerCase()}`,
  ],
}

const STEPS = [
  {
    step: '1',
    title: 'Make it safe',
    description:
      'Move furniture and valuables away from the leak. Put containers under active drips. If water is near electrics, turn off the power at the consumer unit.',
  },
  {
    step: '2',
    title: 'Tell us what is happening',
    description: `Call ${CLIENT.phone} or use the chat above. Describe the problem and we will arrange a same-day callback from a local roofer.`,
  },
  {
    step: '3',
    title: 'Get help fast',
    description:
      'A local roofer calls you back the same day. They can attend, make your property watertight, and then arrange a permanent repair.',
  },
]

const TRUST = [
  { icon: 'lucide:clock', text: 'Same-day callback' },
  { icon: 'lucide:shield-check', text: 'No call-out fee for quotes' },
]

const EMERGENCY_TYPES = [
  {
    title: 'Active roof leaks and water ingress',
    description: `Water coming through the ceiling during heavy rain is the most common roof emergency. Causes range from cracked tiles and failed pointing to blocked gutters overflowing into the roof structure. A roofer traces the leak to source, stops the water entry, and protects interior plasterwork while a permanent repair is scheduled.`,
    link: '/services/roof-repair',
    linkLabel: 'Roof repair',
  },
  {
    title: 'Storm damage and high winds',
    description: `Southwesterly gales coming up the Exe Valley regularly lift ridge tiles, displace slates, and damage flashings. Properties on exposed higher ground around St Leonard's, Pennsylvania, and Mount Pleasant are most at risk. A roofer can tarp the affected areas, secure loose materials, and document damage for insurance claims if needed.`,
    link: '/services/roof-repair',
    linkLabel: 'Roof repair',
  },
  {
    title: 'Missing or slipped tiles',
    description: `Single slipped or missing tiles after high winds expose the felt or batten underneath, which will fail within days if rain continues. Common on Victorian terraces across Heavitree, St James, and Whipton where original slate is increasingly brittle. Individual tiles can be replaced or batch-matched where original materials are still available.`,
    link: '/services/roof-repair',
    linkLabel: 'Roof repair',
  },
  {
    title: 'Chimney damage and lead flashing failure',
    description: `Cracked chimney pots, loose stack masonry, and failed lead flashings are routine emergencies on Exeter's older housing stock. A failed lead apron channels water directly into the loft. A roofer can secure loose pots, fit temporary flashings, and quote separately for permanent rebuild or re-lead work.`,
    link: '/services/chimney-work',
    linkLabel: 'Chimney work',
  },
  {
    title: 'Flat roof failure',
    description: `Felt and EPDM flat roofs on Victorian rear extensions, dormers, and garage roofs typically fail at the seams or upstands. Sudden water ingress through a flat roof usually means a split has opened up. The failure point can be patched with self-adhesive flashings or compatible repair materials to restore watertightness.`,
    link: '/services/flat-roof',
    linkLabel: 'Flat roofing',
  },
  {
    title: 'Fallen branches and impact damage',
    description: `Exeter's mature tree cover means storm-fallen branches regularly puncture roofs in conservation areas around Pennsylvania, Heavitree, and the Cathedral quarter. Debris is removed safely, the structural extent assessed, and the affected area tarped until a permanent repair can be scoped and completed.`,
    link: '/services/roof-repair',
    linkLabel: 'Roof repair',
  },
]

const FAQS = [
  {
    question: 'How quickly can a roofer attend a roof emergency?',
    answer: `For genuine emergencies — active leaks, storm damage, immediate risk — describe it in the chat or call ${CLIENT.phone} for a same-day callback. A local roofer can usually attend central Exeter (EX1, EX2, EX4) the same day and reach surrounding areas like Topsham, Exmouth, and Crediton within a few hours, depending on workload and weather.`,
  },
  {
    question: 'Is there a call-out fee?',
    answer: `Getting a quote through us is free and there is no call-out fee. As a guide, an emergency tarpaulin to make a roof watertight typically costs £150–£300 depending on access and the area covered, with any permanent repair quoted separately. Always confirm the price with the roofer before work begins.`,
  },
  {
    question: 'What about out-of-hours or overnight emergencies?',
    answer: `Roof work after dark is rarely safe, so overnight emergencies are usually handled with phone advice first — isolating electrics, containing leaks internally — and a roofer attending at first light. If there is immediate structural danger to people, call the fire service for emergency make-safe.`,
  },
  {
    question: 'Temporary fix or permanent repair on the day?',
    answer: `The priority is making the roof watertight on the first visit, using tarpaulins or temporary flashings. A permanent repair usually needs properly matched materials and dry conditions, so it is normally quoted separately and scheduled for the next available slot. The temporary work prevents further damage in the meantime.`,
  },
  {
    question: 'What about storm damage and insurance claims?',
    answer: `After major storms, a roofer can provide photographs and a written report documenting the damage and the repair carried out — which most insurers require for a claim — and liaise with loss adjusters where needed.`,
  },
  {
    question: 'Is the roofer insured?',
    answer: `The roofer who attends carries their own public liability insurance. We recommend asking to see a copy and confirming the cover before any work begins.`,
  },
]

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    getLocalBusinessSchema(),
    getWebSiteSchema(),
    {
      '@type': 'WebPage',
      url: page.canonical,
      name: page.title,
      description: page.description,
    },
    getBreadcrumbSchema([
      { name: 'Home', url: BASE_URL },
      { name: 'Emergency', url: page.canonical },
    ]),
    {
      '@type': 'FAQPage',
      mainEntity: FAQS.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: faq.answer,
        },
      })),
    },
  ],
}
---

<BaseLayout page={page} structuredData={structuredData}>
  <!-- Urgent Hero -->
  <section
    class="py-12 md:py-20 px-4"
    style="background: linear-gradient(135deg, #7f1d1d 0%, #991b1b 50%, #b91c1c 100%);"
  >
    <div class="mx-auto max-w-6xl">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
        <div class="flex-1 text-center lg:text-left">
          <div class="inline-flex items-center gap-2 bg-white/10 text-white/90 text-xs font-semibold px-3.5 py-1.5 rounded-full mb-5">
            <Icon name="lucide:alert-triangle" size={14} />
            Emergency Response
          </div>
          <h1 class="font-heading text-[clamp(28px,5vw,48px)] leading-[1.08] text-white mb-5">
            Emergency roof repair in <span class="text-amber-300">{CLIENT.area}</span>
          </h1>
          <p class="text-lg text-white/80 leading-relaxed mb-8 max-w-xl mx-auto lg:mx-0">
            Leaking roof? Storm damage? Describe it in the chat or call now, and {CLIENT.businessName} gets you a same-day callback from a local roofer across {CLIENT.area} and {CLIENT.region} who can make your property watertight fast.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start mb-8">
            <a
              href={`tel:${phoneClean}`}
              class="inline-flex items-center justify-center gap-3 bg-white text-red-700 font-bold text-lg px-8 py-4 rounded-xl no-underline shadow-lg hover:shadow-xl transition-shadow"
              data-track="phone_call:emergency_hero"
            >
              <Icon name="lucide:phone" size={22} />
              Call Now: {CLIENT.phone}
            </a>
          </div>
          <div class="flex flex-wrap gap-5 justify-center lg:justify-start text-white/70">
            {TRUST.map((item) => (
              <div class="flex items-center gap-2 text-sm">
                <Icon name={item.icon} size={16} />
                {item.text}
              </div>
            ))}
          </div>
        </div>
        <div id="quote" class="flex-1 flex justify-center w-full max-w-[440px]">
          <AiChatIntake client:visible />
        </div>
      </div>
    </div>
  </section>

  <!-- What to Do -->
  <section class="py-16 px-4">
    <div class="mx-auto max-w-4xl">
      <h2 class="font-heading text-2xl md:text-[32px] text-slate-800 text-center mb-10">
        Got a roof emergency? Here is what to do.
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {STEPS.map((item) => (
          <div class="card p-6">
            <div
              class="w-10 h-10 rounded-xl flex items-center justify-center font-heading text-base mb-4"
              style="background: #fef2f2; color: #dc2626;"
            >
              {item.step}
            </div>
            <h3 class="font-heading text-base text-slate-800 mb-2">{item.title}</h3>
            <p class="text-sm text-slate-500 leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Emergency Pricing -->
  <section class="py-16 px-4 section-warm">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="font-heading text-2xl text-slate-800 mb-4">
        Free quote, no call-out fee
      </h2>
      <p class="text-slate-500 leading-relaxed mb-8 max-w-lg mx-auto">
        Getting a quote through us is free and there is no call-out fee. As a guide, an emergency tarpaulin to make your roof watertight typically costs £150–£300, with any permanent repair quoted separately. You will know the likely cost before any work is agreed.
      </p>
      <a
        href={`tel:${phoneClean}`}
        class="btn-primary !bg-red-600 hover:!bg-red-700"
        style="box-shadow: 0 2px 8px rgba(220,38,38,0.3);"
        data-track="phone_call:emergency_pricing"
      >
        <Icon name="lucide:phone" size={18} />
        Call {CLIENT.phone}
      </a>
    </div>
  </section>

  <!-- Emergency Types -->
  <section class="py-16 px-4">
    <div class="mx-auto max-w-6xl">
      <div class="text-center mb-10">
        <h2 class="font-heading text-2xl md:text-[32px] text-slate-800 mb-3">
          Common roof emergencies
        </h2>
        <p class="text-slate-500 max-w-2xl mx-auto">
          The most frequent roof emergencies across {CLIENT.area} and the surrounding area. Describe yours in the chat and a local roofer can make it safe and watertight on the first visit.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {EMERGENCY_TYPES.map((item) => (
          <div class="card p-6 flex flex-col">
            <h3 class="font-heading text-lg text-slate-800 mb-3">{item.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed mb-5 flex-1">
              {item.description}
            </p>
            <a
              href={item.link}
              class="text-sm font-semibold inline-flex items-center gap-1.5 no-underline self-start"
              style="color: var(--color-brand);"
            >
              {item.linkLabel}
              <Icon name="lucide:arrow-right" size={14} />
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Local Emergency Context -->
  <section class="py-16 px-4 section-warm">
    <div class="mx-auto max-w-3xl space-y-10">
      <h2 class="font-heading text-2xl md:text-[32px] text-slate-800 text-center mb-2">
        Roof emergencies in {CLIENT.area}
      </h2>

      <div>
        <h3 class="font-heading text-lg text-slate-800 mb-3">
          When emergencies happen
        </h3>
        <p class="text-slate-600 leading-relaxed">
          Roof emergencies in {CLIENT.area} cluster around two periods. Autumn and winter storms — particularly southwesterly fronts coming up the Exe estuary — are the main cause, with the worst damage typically arriving between November and February. The second cluster is the freeze-thaw transition in late winter and early spring, where water that has worked into hairline tile cracks expands and fractures the material. Heavy summer downpours, while less frequent, can overwhelm gutter systems and force water back under the eaves of properties with blocked rainwater goods.
        </p>
      </div>

      <div>
        <h3 class="font-heading text-lg text-slate-800 mb-3">
          Emergencies by Exeter property type
        </h3>
        <p class="text-slate-600 leading-relaxed">
          Different parts of {CLIENT.area} present different emergency patterns. Victorian and Edwardian terraces in St James, Heavitree, St Leonard's, and Mount Pleasant most often see slipped Welsh slates, failed pointing on chimney stacks, and lead flashing failure where rear extensions meet the main roof. The 1930s housing stock in Wonford, Whipton, and Pinhoe typically presents clay or concrete tile slippage and ridge tile displacement after high winds. Newer estates in Cranbrook, Marsh Barton, and outer Pinhoe see fewer storm-related emergencies but occasional construction-period defects — typically poorly bedded ridge tiles or flashings that loosen in the first few years. Period properties in the Cathedral and Quay conservation areas have the most complex emergencies because matching original materials is essential.
        </p>
      </div>

      <div>
        <h3 class="font-heading text-lg text-slate-800 mb-3">
          Coverage and response across Exeter
        </h3>
        <p class="text-slate-600 leading-relaxed">
          For genuine emergencies — active leaks, storm damage, structural risk — describe the problem in the chat or call, and you will get a same-day callback from a local roofer. Roofers prioritise same-day attendance to the central postcodes (EX1, EX2, EX4) and can typically reach Topsham, Exmouth, Crediton, and Cranbrook within a few hours. They carry tarpaulins, common slate and tile types, and self-adhesive flashings to make a roof watertight in one visit. Where a permanent repair is not possible the same day — for instance where bespoke materials need sourcing — the affected area is made secure and the return visit scheduled promptly.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="py-16 px-4">
    <FaqSection title="Emergency Roof Repair — Common Questions" faqs={FAQS} />
  </section>

  <CtaSection
    heading={`Roof emergency in ${CLIENT.area}?`}
    subheading={`Call us now on ${CLIENT.phone}, or describe it in the chat for a same-day callback from a local roofer across ${CLIENT.area} and ${CLIENT.region}.`}
  />
</BaseLayout>
