---
import { Icon } from 'astro-icon/components'
import { CLIENT } from '../data/clientConfig'
import { buildStructuredData } from '../utils/seo'
import type { SeoPageData } from '../types'
import BaseLayout from '../layouts/BaseLayout.astro'

const BASE_URL = `https://${CLIENT.domain}`

const page: SeoPageData = {
  title: `Page Not Found | ${CLIENT.businessName}`,
  description: `Sorry, we couldn't find the page you were looking for. ${CLIENT.businessName} — trusted roofers in ${CLIENT.area}.`,
  canonical: `${BASE_URL}/404`,
  ogImage: `${BASE_URL}/og-image.jpg`,
  type: 'website',
  keywords: [],
}

const structuredData = buildStructuredData(page, [])
const phoneClean = CLIENT.phone.replace(/\s/g, '')
---

<BaseLayout page={page} structuredData={structuredData}>
  <section class="py-20 px-4 text-center">
    <div class="mx-auto max-w-md">
      <div class="font-heading text-6xl text-slate-200 mb-4">404</div>
      <h1 class="font-heading text-2xl text-slate-800 mb-3">Page not found</h1>
      <p class="text-slate-500 mb-8">
        Sorry, the page you're looking for doesn't exist. Let's get you back on track.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="btn-primary no-underline">
          <Icon name="lucide:home" size={17} />
          Back to Home
        </a>
        <a href={`tel:${phoneClean}`} class="btn-secondary">
          Call {CLIENT.phone}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
