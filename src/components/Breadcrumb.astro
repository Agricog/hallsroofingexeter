---
interface Crumb {
  label: string
  href?: string
}

interface Props {
  items: Crumb[]
}

const { items } = Astro.props
---

<div class="bg-slate-50 border-b border-slate-100">
  <div class="mx-auto max-w-6xl px-4 py-3">
    <nav class="flex items-center gap-2 text-sm text-slate-400" aria-label="Breadcrumb">
      {items.map((item, i) => (
        <>
          {i > 0 && <span>/</span>}
          {item.href ? (
            <a href={item.href} class="hover:text-slate-600 no-underline text-slate-400">
              {item.label}
            </a>
          ) : (
            <span class="text-slate-600">{item.label}</span>
          )}
        </>
      ))}
    </nav>
  </div>
</div>
