---
import { Icon } from 'astro-icon/components'
import { CLIENT } from '../data/clientConfig'

const yearsInBusiness = new Date().getFullYear() - CLIENT.yearEstablished

const TRUST_ITEMS = [
  {
    icon: 'lucide:star',
    value: `${CLIENT.googleReviewRating}/5`,
    label: `${CLIENT.googleReviewCount} Google Reviews`,
  },
  {
    icon: 'lucide:shield-check',
    value: `£${CLIENT.insuranceAmount}`,
    label: 'Public Liability',
  },
  {
    icon: 'lucide:award',
    value: `${yearsInBusiness} Years`,
    label: `Established ${CLIENT.yearEstablished}`,
  },
  {
    icon: 'lucide:clock',
    value: 'Same Day',
    label: 'Response Guaranteed',
  },
]
---

<div class="bg-white border-y border-slate-100">
  <div class="mx-auto max-w-6xl px-4 py-5">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
      {TRUST_ITEMS.map((item) => (
        <div class="flex items-center gap-3">
          <div
            class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0"
            style="background: var(--color-brand-50);"
          >
            <Icon name={item.icon} size={20} style="color: var(--color-brand);" />
          </div>
          <div>
            <div class="font-semibold text-sm text-slate-800 leading-tight">
              {item.value}
            </div>
            <div class="text-xs text-slate-500 leading-tight">
              {item.label}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>
