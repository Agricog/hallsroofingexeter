---
// ============================================================
// FaqSection — Native <details>/<summary> accordion
// Zero JS, fully accessible, semantic, animatable with CSS
// ============================================================
import { CLIENT } from '../data/clientConfig'

interface FaqItem {
  question: string
  answer: string
}

interface Props {
  title?: string
  faqs?: FaqItem[]
  maxItems?: number
}

const {
  title = 'Frequently Asked Questions',
  faqs = CLIENT.faqs,
  maxItems,
} = Astro.props

const displayFaqs = maxItems ? faqs.slice(0, maxItems) : faqs
---

<div class="mx-auto max-w-3xl">
  <h2 class="font-heading text-2xl md:text-[32px] text-slate-800 text-center mb-10">
    {title}
  </h2>

  <div class="space-y-2">
    {displayFaqs.map((faq) => (
      <details class="faq-item">
        <summary>
          <span>{faq.question}</span>
        </summary>
        <div class="faq-answer">{faq.answer}</div>
      </details>
    ))}
  </div>
</div>
